  "item": [
    {
      "name": "Phase 1 - Core Endpoints",
      "item": [
        {
          "name": "1.1 Create Post (by User)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authorId\": {{user_id}},\n  \"authorType\": \"USER\",\n  \"content\": \"Hello world from Alice!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/posts",
              "host": ["{{base_url}}"],
              "path": ["api", "posts"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('post_id', json.id);",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has post id', () => pm.expect(json.id).to.be.a('number'));",
                  "pm.test('Content matches', () => pm.expect(json.content).to.eql('Hello world from Alice!'));"
                ]
              }
            }
          ]
        },
